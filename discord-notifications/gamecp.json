{
  "$schema": "../../packages/build/gamecp-manifest.schema.json",
  "extension_id": "discord-notifications",
  "version": "2.0.1",
  "name": "Discord Notifications",
  "description": "Send game server alerts, crash notifications, player activity, and status updates to Discord channels via webhooks with customizable templates",
  "author": "GameCP Team",
  "ui_bundle": "dist/index.js",
  "handlers_bundle": "dist/handlers.js",
  "integrity": "sha384-yRKJH2jWNXdobHK/4bFUBZcOmCk46a3Ya42By1JgSnfYMwiZ5mUS/EOiTKC3xzmb",
  "ui_injection": [
    {
      "method": "MOUNT",
      "target": "server.sidebar.nav",
      "component": "DiscordIcon",
      "order": 50
    },
    {
      "method": "HANDLER",
      "target": "server.page.extensions",
      "component": "SettingsPage",
      "route_path": "/game-servers/:id/extensions/discord"
    },
    {
      "method": "HANDLER",
      "target": "settings.page",
      "component": "DiscordAdminPage",
      "route_path": "/extensions/discord-notifications"
    }
  ],
  "internal_logic": {
    "api_routes": [
      {
        "method": "GET",
        "path": "/config",
        "handler_export": "getConfig",
        "description": "Get admin global configuration"
      },
      {
        "method": "PUT",
        "path": "/config",
        "handler_export": "saveConfig",
        "timeout_ms": 5000,
        "description": "Save admin global configuration"
      },
      {
        "method": "GET",
        "path": "/webhooks",
        "handler_export": "getWebhooks",
        "description": "Get server webhooks"
      },
      {
        "method": "POST",
        "path": "/webhooks",
        "handler_export": "saveWebhook",
        "timeout_ms": 3000,
        "description": "Add or update a server webhook"
      },
      {
        "method": "DELETE",
        "path": "/webhooks",
        "handler_export": "deleteWebhook",
        "description": "Remove a server webhook"
      },
      {
        "method": "PUT",
        "path": "/overrides",
        "handler_export": "saveOverrides",
        "timeout_ms": 3000,
        "description": "Save per-server event template overrides"
      },
      {
        "method": "POST",
        "path": "/test",
        "handler_export": "testWebhook",
        "timeout_ms": 10000,
        "description": "Send test message to a Discord webhook"
      }
    ],
    "event_listeners": [
      {
        "event": "server.status.crash",
        "handler_export": "handleCrash",
        "async": true,
        "description": "Send alert when server crashes"
      },
      {
        "event": "server.status.started",
        "handler_export": "handleStart",
        "async": true,
        "description": "Notify when server starts"
      },
      {
        "event": "server.status.stopped",
        "handler_export": "handleStop",
        "async": true,
        "description": "Notify when server stops"
      },
      {
        "event": "server.player.join",
        "handler_export": "handlePlayerJoin",
        "async": true,
        "description": "Notify when a player joins"
      },
      {
        "event": "server.player.leave",
        "handler_export": "handlePlayerLeave",
        "async": true,
        "description": "Notify when a player leaves"
      },
      {
        "event": "server.lifecycle.created",
        "handler_export": "handleServerCreated",
        "async": true,
        "description": "Notify when a server is created"
      },
      {
        "event": "server.lifecycle.deleted",
        "handler_export": "handleServerDeleted",
        "async": true,
        "description": "Notify when a server is deleted"
      }
    ]
  },
  "sandbox_config": {
    "db_collections": [
      "config",
      "server_configs",
      "webhooks",
      "logs"
    ],
    "permissions": [
      "network.outbound"
    ],
    "resource_limits": {
      "memory_mb": 128,
      "timeout_ms": 10000,
      "max_db_queries_per_request": 10
    }
  },
  "metadata": {
    "icon": "assets/icon.png",
    "readme": "README.md",
    "category": "notifications",
    "homepage": "https://github.com/GameCP/apps/blob/main/discord-notifications/README.md",
    "repository": "https://github.com/GameCP/apps/tree/main/discord-notifications",
    "license": "MIT",
    "tags": [
      "discord",
      "webhooks",
      "notifications",
      "alerts",
      "monitoring",
      "players"
    ],
    "screenshots": [
      "assets/screenshots/settings-page.png",
      "assets/screenshots/discord-message.png"
    ]
  }
}
